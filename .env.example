# Supabase (create project at https://supabase.com, then copy from Settings > API)
# Use either VITE_* or NEXT_PUBLIC_* names (both work):
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Or:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# For one-time data import (npm run import:data): your login email and password
# IMPORT_USER_EMAIL=your@email.com
# IMPORT_USER_PASSWORD=your-password

# Market News API (for sentiment/news timeline overlay)
# Get free API key at https://newsapi.org (100 requests/day free tier)
VITE_NEWS_API_KEY=your-newsapi-key

# Sentiment/Fear & Greed Index (optional)
# CNN Fear & Greed Index is free: https://www.cnnbusiness.com/markets/fear-and-greed
# Or use an alternative sentiment API key if preferred
# VITE_SENTIMENT_API_KEY=your-sentiment-api-key
